@model SkyBooker.Web.Models.FlightViewModel

@{
    ViewData["Title"] = "Yeni Uçuş Ekle";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-lg border-top border-primary border-3">
                <div class="card-header bg-white text-center py-3">
                    <h3 class="fw-bold text-primary mb-0">➕ Yeni Uçuş Oluştur</h3>
                    <p class="text-muted mb-0">Sisteme yeni bir sefer tanımlayın.</p>
                </div>
                <div class="card-body p-4">
                    
                    @if (TempData["Hata"] != null)
                    {
                        <div class="alert alert-danger fw-bold">❌ @TempData["Hata"]</div>
                    }

                    <form asp-action="UcusEkle" asp-controller="Admin" method="post">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Uçuş Kodu</label>
                                <input type="text" asp-for="FlightCode" class="form-control text-uppercase" required placeholder="Örn: XQ1234" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Bilet Fiyatı (₺)</label>
                                <input type="number" step="0.01" asp-for="Price" class="form-control" required placeholder="Örn: 1450.50" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Kalkış Şehri</label>
                                <input type="text" asp-for="Departure" class="form-control" required placeholder="Örn: Antalya" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Varış Şehri</label>
                                <input type="text" asp-for="Arrival" class="form-control" required placeholder="Örn: İzmir" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Kalkış Tarihi ve Saati</label>
                            <input type="datetime-local" asp-for="DepartureTime" class="form-control" required />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/Admin/Index" class="btn btn-secondary px-4 fw-bold">İptal</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold">✈️ Uçuşu Kaydet</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>