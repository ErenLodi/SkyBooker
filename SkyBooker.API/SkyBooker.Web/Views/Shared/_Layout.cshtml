<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SkyBooker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">✈️ SkyBooker</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#AnaMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="AnaMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link text-white fs-5" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold fs-5 ms-3" asp-controller="Admin" asp-action="Index">⚙️ Admin Paneli</a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        @if (!string.IsNullOrEmpty(Context.Request.Cookies["JWToken"]))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="Biletlerim">🎫 Biletlerim</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-controller="Home" asp-action="Profilim">👤 Profilim</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-danger fw-bold shadow-sm" asp-controller="Auth" asp-action="Logout">🚪 Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white fw-bold" asp-controller="Auth" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-light text-primary fw-bold shadow-sm" asp-controller="Auth" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5 pt-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted text-center py-4 mt-5 bg-white shadow-sm">
        <div class="container fw-bold">
            &copy; 2026 - SkyBooker Uçak Bilet Rezervasyon Sistemi | Süleyman Demirel Üniversitesi
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>