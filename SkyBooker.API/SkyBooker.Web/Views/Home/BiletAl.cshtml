@{
    ViewData["Title"] = "Bilet Satın Al";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-warning text-dark text-center py-3">
                    <h4 class="fw-bold mb-0">🎫 Yolcu Bilgilerini Giriniz</h4>
                </div>
                <div class="card-body p-5">
                    
                    <form asp-action="BiletAl" asp-controller="Home" method="post">
                        
                        <input type="hidden" name="FlightId" value="@ViewBag.UcusId" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted">Yolcu Adı ve Soyadı</label>
                            <input type="text" class="form-control form-control-lg" name="PassengerName" required placeholder="Örn: Eren Lodi" autocomplete="off" />
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold text-muted">Koltuk Seçimi</label>
                            <input type="text" class="form-control form-control-lg text-uppercase" name="SeatNumber" required placeholder="Örn: 14A, 22F" maxlength="3" autocomplete="off" />
                            <small class="text-muted mt-1 d-block">Lütfen geçerli bir koltuk numarası giriniz.</small>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="submit" class="btn btn-success btn-lg fw-bold shadow-sm">
                                ✈️ Rezervasyonu Tamamla
                            </button>
                            <a href="/Home/Index" class="btn btn-outline-secondary fw-bold">
                                İptal ve Geri Dön
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>